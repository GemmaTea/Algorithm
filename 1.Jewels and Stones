import java.util.HashMap;

class Solution {
    public int numJewelsInStones(String jewels, String stones) {
        int count=0;
        
        HashMap<Character,Integer> h = new HashMap<>();
        char[] j = jewels.toCharArray();
        for(char c : j){
        if(h.containsKey(c)==false)
        {
          h.put(c,1);  
        }}
           
        char[] st = stones.toCharArray();
        for(char c : st)
        {
            if(h.containsKey(c))
            {
                count++;
            }
                
        }
        return count;
    }
}
